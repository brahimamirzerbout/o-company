{
  "name": "@o/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema.ts",
    "./seed": "./src/seed.ts"
  },
  "scripts": {
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "reset": "tsx src/migrate.ts --reset",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@o/types": "workspace:*",
    "drizzle-orm": "0.36.0",
    "drizzle-kit": "0.28.0",
    "postgres": "3.4.4",
    "tsx": "4.19.2"
  },
  "devDependencies": {
    "typescript": "5.6.3"
  }
}
