# =============================================================================
# o.company · environment configuration
# =============================================================================
# Copy this file to `.env.local` in each app and fill in your values. Vercel
# reads these straight from the project settings. NEVER commit `.env.local`.

# Database — Postgres connection string. Supabase, Neon, and RDS all work.
DATABASE_URL="postgresql://o:o@localhost:5432/o_company"

# JWT — symmetric key for session cookies. Generate with:
#   openssl rand -hex 64
JWT_SECRET=""
# 32-byte AES key for column-level encryption. Same generator.
ENCRYPTION_KEY=""

# Stripe — get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Email — Resend (https://resend.com). Free tier: 3k emails/mo.
RESEND_API_KEY=""
EMAIL_FROM="hello@o.company"
EMAIL_REPLY_TO="oshay@o.company"

# WalletConnect / web3
WALLETCONNECT_PROJECT_ID=""
ALCHEMY_KEY=""                # for ENS / on-chain reads
INFURA_KEY=""                  # backup

# App URLs
NEXT_PUBLIC_APP_URL="https://app.o.company"
NEXT_PUBLIC_WEB_URL="https://o.company"

# Feature flags — flip these to roll out features gradually
FEATURE_CRYPTO_PAYMENTS="false"
FEATURE_AI_BRIEFING="false"
FEATURE_SOC2_MODE="false"

# Observability
SENTRY_DSN=""
PLAUSIBLE_DOMAIN=""

# S3 / R2 for file storage
S3_ENDPOINT=""
S3_BUCKET="o-company-uploads"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="auto"

# Storage backend: "r2" (default, Cloudflare) or "s3" (AWS, MinIO, R2 via S3 compat)
STORAGE_BACKEND="r2"
R2_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
R2_BUCKET="o-photos"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PUBLIC_HOST="https://photos.o.company"

# Photo pipeline — Replicate API (https://replicate.com/account/api-tokens)
REPLICATE_API_TOKEN=""

# Worker → API service token (long random string)
# Generate: openssl rand -hex 32
API_SERVICE_TOKEN=""
